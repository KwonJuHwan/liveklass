          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \r\n    status AS metric, \r\n    COUNT(*) AS value\r\nFROM (\r\n    SELECT \r\n        session_id,\r\n        CASE  \r\n            WHEN MAX(IF(event_type = 'PAYMENT_COMPLETED', 1, 0)) = 0 THEN '결제 미완료 (이탈)'\r\n            WHEN MAX(IF(event_type = 'PAYMENT_COMPLETED' AND coupon_id IS NOT NULL, 1, 0)) = 1 THEN '쿠폰 사용 결제'\r\n            ELSE '쿠폰 미사용 결제'\r\n        END AS status\r\n    FROM payment_logs\r\n    WHERE session_id IN (\r\n        SELECT session_id \r\n        FROM payment_logs \r\n        WHERE event_type = 'ADD_TO_CART'\r\n    )\r\n    GROUP BY session_id\r\n) AS funnel\r\nGROUP BY status;",
          "refId": "A",
