                      "dataset": "liveclass_logs",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT\r\n    CONCAT(IF(is_main_exposed=1, '메인 노출 O', '메인 노출 X'), ' / ', IF(course_fee > 0, '유료', '무료')) AS metric,\r\n    COUNT(*) AS value\r\nFROM traffic_logs\r\nGROUP BY course_id, is_main_exposed, course_fee\r\nORDER BY value DESC;",
