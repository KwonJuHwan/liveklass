    "panel-4": {
      "kind": "Panel",
      "spec": {
        "data": {
          "kind": "QueryGroup",
          "spec": {
            "queries": [
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "efo7az1v4qlmoe"
                    },
                    "group": "mysql",
                    "kind": "DataQuery",
                    "spec": {
                      "dataset": "liveclass_logs",
                      "editorMode": "code",
                      "format": "table",
                      "rawQuery": true,
                      "rawSql": "SELECT\r\n    payment_method,\r\n    completed,\r\n    failed\r\nFROM (\r\n    SELECT\r\n        payment_method,\r\n        SUM(CASE WHEN event_type = 'PAYMENT_COMPLETED' THEN 1 ELSE 0 END) AS completed,\r\n        SUM(CASE WHEN event_type = 'PAYMENT_FAILED' THEN 1 ELSE 0 END) AS failed,\r\n        COUNT(*) AS total_cnt\r\n    FROM payment_logs\r\n    WHERE event_type IN ('PAYMENT_COMPLETED', 'PAYMENT_FAILED')\r\n    GROUP BY payment_method\r\n) t\r\nORDER BY total_cnt ASC;",
                      "sql": {
                        "columns": [
                          {
                            "parameters": [],
                            "type": "function"
                          }
                        ],
