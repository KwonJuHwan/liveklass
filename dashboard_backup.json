      "panel-3": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "afo442jfswvlsb"
                      },
                      "group": "mysql",
                      "kind": "DataQuery",
                      "spec": {
                        "dataset": "liveclass_logs",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n    payment_method AS '결제 수단', \r\n    COUNT(*) AS '총 시도',\r\n    SUM(IF(event_type = 'PAYMENT_FAILED', 1, 0)) AS '에러 건수',\r\n    ROUND(SUM(IF(event_type = 'PAYMENT_FAILED', 1, 0)) / COUNT(*) * 100, 1) AS '에러율(%)'\r\nFROM payment_logs\r\nWHERE event_type IN ('PAYMENT_COMPLETED', 'PAYMENT_FAILED')\r\nGROUP BY payment_method\r\nORDER BY `에러율(%)` DESC;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
