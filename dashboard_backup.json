            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "afo442jfswvlsb"
                      },
                      "group": "mysql",
                      "kind": "DataQuery",
                      "spec": {
                        "dataset": "liveclass_logs",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT \r\n    CAST(episode_number AS CHAR) AS '회차', \r\n    COUNT(DISTINCT session_id) AS '시청 유저 수'\r\nFROM traffic_logs\r\nWHERE course_id = 'C_1001'\r\nGROUP BY episode_number\r\nORDER BY episode_number;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        }
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "수강생들이 몇 화에서 주로 이탈하는지 파악하여 콘텐츠 개선점 도출",
          "id": 1,
          "links": [],
