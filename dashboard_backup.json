      "panel-2": {
        "kind": "Panel",
        "spec": {
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "afo442jfswvlsb"
                      },
                      "group": "mysql",
                      "kind": "DataQuery",
                      "spec": {
                        "dataset": "liveclass_logs",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n    coupon_status AS metric,\r\n    ROUND(SUM(is_paid) / COUNT(*) * 100, 1) AS value\r\nFROM (\r\n    SELECT session_id,\r\n        IF(MAX(coupon_id) IS NOT NULL, '쿠폰 사용', '쿠폰 미사용') AS coupon_status,\r\n        MAX(IF(event_type = 'PAYMENT_COMPLETED', 1, 0)) AS is_paid\r\n    FROM payment_logs\r\n    WHERE event_type IN ('CHECKOUT_STARTED', 'PAYMENT_COMPLETED', 'PAYMENT_FAILED')\r\n    GROUP BY session_id\r\n) AS session_summary\r\nGROUP BY coupon_status;",
                        "sql": {
                          "columns": [
                            {
                              "parameters": [],
                              "type": "function"
                            }
                          ],
                          "groupBy": [
                            {
                              "property": {
                                "type": "string"
                              },
                              "type": "groupBy"
                            }
                          ],
                          "limit": 50
                        }
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": []
            }
          },
          "description": "결제창에 진입한 유저 중, 쿠폰을 가진 사람과 없는 사람의 실제 결제 성공 비율 차이 증명.",
          "id": 2,
          "links": [],
          "title": "쿠폰 사용 여부에 따른 결제 전환율",
          "vizConfig": {
